<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit <%= v.name %> | Nayapankh Admin</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('_nav', { page: 'dashboard' }) %>
  <main class="centered">
    <div class="card">
      <div class="card-header">
        <a href="/admin/volunteer/<%= v.id %>" class="back-link">← Back to Profile</a>
        <h1>Edit Volunteer</h1>
      </div>
      <% if(error){ %><div class="alert alert-error">❌ <%= error %></div><% } %>
      <form method="POST" action="/admin/volunteer/<%= v.id %>/edit" class="form">

        <div class="section-label">Personal Information</div>
        <div class="form-row">
          <div class="form-group">
            <label>Full Name <span class="req">*</span></label>
            <input type="text" name="name" value="<%= v.name %>" required>
          </div>
          <div class="form-group">
            <label>Gender</label>
            <select name="gender">
              <option value="">Prefer not to say</option>
              <% ['Male','Female','Other'].forEach(g => { %>
                <option <%= v.gender===g?'selected':'' %>><%= g %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Email <span class="req">*</span></label>
            <input type="email" name="email" value="<%= v.email %>" required>
          </div>
          <div class="form-group">
            <label>Phone <span class="req">*</span></label>
            <input type="tel" name="phone" value="<%= v.phone %>" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Age <span class="req">*</span></label>
            <input type="number" name="age" min="14" max="100" value="<%= v.age %>" required>
          </div>
          <div class="form-group">
            <label>Status</label>
            <select name="status">
              <% ['Pending','Active','Inactive'].forEach(s => { %>
                <option <%= v.status===s?'selected':'' %>><%= s %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Address</label>
          <input type="text" name="address" value="<%= v.address %>">
        </div>

        <div class="section-label">Volunteer Details</div>
        <div class="form-row">
          <div class="form-group">
            <label>Skills</label>
            <input type="text" name="skills" value="<%= v.skills %>">
          </div>
          <div class="form-group">
            <label>Availability</label>
            <select name="availability">
              <option value="">Select…</option>
              <% ['Weekdays','Weekends','Both','Full-time'].forEach(a => { %>
                <option <%= v.availability===a?'selected':'' %>><%= a %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Emergency Contact</label>
          <input type="text" name="emergency_contact" value="<%= v.emergency_contact %>">
        </div>
        <div class="form-group">
          <label>Admin Notes</label>
          <textarea name="notes" rows="3" placeholder="Internal notes…"><%= v.notes %></textarea>
        </div>

        <div class="btn-group">
          <button type="submit" class="btn btn-primary">Save Changes</button>
          <a href="/admin/volunteer/<%= v.id %>" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </main>
  <footer><p>© 2025 Nayapankh VMS</p></footer>
</body>
</html>
