<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>API Keys | Nayapankh Admin</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('_nav', { page: 'apikeys' }) %>
  <main>
    <div class="page-header">
      <div>
        <h1>API Keys</h1>
        <p>Use keys to authenticate REST API requests via <code>X-Api-Key</code> header.</p>
      </div>
    </div>

    <% if (newKey) { %>
    <div class="alert alert-success" style="max-width:700px">
      🔑 New API Key (copy now — shown only once):<br>
      <code class="key-display"><%= newKey %></code>
    </div>
    <% } %>

    <div class="card" style="max-width:700px;padding:1.5rem">
      <form method="POST" action="/admin/api-keys" class="form" style="flex-direction:row;gap:.75rem">
        <input type="text" name="label" placeholder="Key label e.g. Mobile App" required style="flex:1">
        <button class="btn btn-primary">Generate Key</button>
      </form>
    </div>

    <div class="table-wrap" style="max-width:700px;margin-top:1.5rem">
      <% if (!keys.length) { %>
        <div class="empty-state"><p>No API keys yet.</p></div>
      <% } else { %>
      <table>
        <thead><tr><th>Label</th><th>Prefix</th><th>Created</th><th></th></tr></thead>
        <tbody>
          <% keys.forEach(k => { %>
          <tr>
            <td><strong><%= k.label %></strong></td>
            <td><code><%= k.key_prefix %>…</code></td>
            <td class="muted"><%= new Date(k.created_at).toLocaleDateString('en-IN') %></td>
            <td>
              <form method="POST" action="/admin/api-keys/delete/<%= k.id %>"
                    onsubmit="return confirm('Revoke this key?')">
                <button class="btn btn-xs btn-danger">Revoke</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <div class="card" style="max-width:700px;margin-top:1.5rem;padding:1.5rem">
      <div class="section-label">API Reference</div>
      <div class="api-ref">
        <div class="api-row"><span class="method get">GET</span>    <code>/api/v1/volunteers</code> — List all</div>
        <div class="api-row"><span class="method get">GET</span>    <code>/api/v1/volunteers/:id</code> — Get one</div>
        <div class="api-row"><span class="method post">POST</span>  <code>/api/v1/volunteers</code> — Create</div>
        <div class="api-row"><span class="method patch">PATCH</span><code>/api/v1/volunteers/:id</code> — Update</div>
        <div class="api-row"><span class="method del">DELETE</span> <code>/api/v1/volunteers/:id</code> — Delete</div>
      </div>
      <p class="hint" style="text-align:left;margin-top:.75rem">All requests require <code>X-Api-Key: &lt;your-key&gt;</code> header.</p>
    </div>
  </main>
  <footer><p>© 2025 Nayapankh VMS</p></footer>
</body>
</html>
