<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= v.name %> | Nayapankh Admin</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('_nav', { page: 'dashboard' }) %>
  <main>
    <div class="page-header">
      <div>
        <a href="/admin/dashboard" class="back-link">← Back to Dashboard</a>
        <h1><%= v.name %></h1>
        <span class="badge badge-<%= v.status.toLowerCase() %>"><%= v.status %></span>
      </div>
      <div class="btn-group">
        <a href="/admin/volunteer/<%= v.id %>/edit" class="btn btn-primary">Edit Profile</a>
        <form method="POST" action="/admin/volunteer/<%= v.id %>/delete"
              onsubmit="return confirm('Permanently delete <%= v.name %>?')">
          <button class="btn btn-danger">Delete</button>
        </form>
      </div>
    </div>

    <div class="profile-grid">
      <div class="profile-card">
        <div class="profile-avatar"><%= v.name.charAt(0).toUpperCase() %></div>
        <div class="profile-name"><%= v.name %></div>
        <div class="profile-meta"><%= v.email %></div>
        <div class="profile-meta"><%= v.phone %></div>
        <% if(v.skills){ %><div class="tag mt-1"><%= v.skills %></div><% } %>
      </div>

      <div class="info-grid">
        <div class="info-block"><div class="info-label">Age</div><div class="info-val"><%= v.age %></div></div>
        <div class="info-block"><div class="info-label">Gender</div><div class="info-val"><%= v.gender || '—' %></div></div>
        <div class="info-block"><div class="info-label">Address</div><div class="info-val"><%= v.address || '—' %></div></div>
        <div class="info-block"><div class="info-label">Availability</div><div class="info-val"><%= v.availability || '—' %></div></div>
        <div class="info-block"><div class="info-label">Emergency Contact</div><div class="info-val"><%= v.emergency_contact || '—' %></div></div>
        <div class="info-block"><div class="info-label">Registered</div><div class="info-val"><%= new Date(v.created_at).toLocaleString('en-IN') %></div></div>
        <div class="info-block"><div class="info-label">Last Updated</div><div class="info-val"><%= new Date(v.updated_at).toLocaleString('en-IN') %></div></div>
        <% if(v.notes){ %>
        <div class="info-block full-width"><div class="info-label">Notes</div><div class="info-val"><%= v.notes %></div></div>
        <% } %>
      </div>
    </div>
  </main>
  <footer><p>© 2025 Nayapankh VMS</p></footer>
</body>
</html>
