<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | Nayapankh Admin</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('_nav', { page: 'dashboard' }) %>
  <main>

    <!-- Stats Bar -->
    <div class="stats-bar">
      <a href="/admin/dashboard" class="stat-chip <%= !status ? 'active' : '' %>">
        <span class="chip-num"><%= stats.total %></span> All
      </a>
      <a href="/admin/dashboard?status=Active" class="stat-chip active-chip <%= status==='Active' ? 'active' : '' %>">
        <span class="chip-num"><%= stats.active %></span> Active
      </a>
      <a href="/admin/dashboard?status=Pending" class="stat-chip pending-chip <%= status==='Pending' ? 'active' : '' %>">
        <span class="chip-num"><%= stats.pending %></span> Pending
      </a>
      <a href="/admin/dashboard?status=Inactive" class="stat-chip inactive-chip <%= status==='Inactive' ? 'active' : '' %>">
        <span class="chip-num"><%= stats.inactive %></span> Inactive
      </a>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
      <form method="GET" action="/admin/dashboard" class="search-form">
        <input type="hidden" name="status" value="<%= status %>">
        <input type="text" name="q" value="<%= q %>" placeholder="Search name, email, skills…">
        <button type="submit" class="btn btn-secondary">Search</button>
        <% if (q || status) { %><a href="/admin/dashboard" class="btn btn-ghost btn-sm">✕ Clear</a><% } %>
      </form>
      <a href="/" target="_blank" class="btn btn-primary btn-sm">+ New Volunteer</a>
    </div>

    <!-- Table -->
    <div class="table-wrap">
      <% if (!volunteers.length) { %>
        <div class="empty-state">
          <div style="font-size:3rem">📋</div>
          <p>No volunteers found.</p>
        </div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>#</th><th>Name</th><th>Contact</th><th>Age</th>
            <th>Skills</th><th>Availability</th><th>Status</th><th>Registered</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% volunteers.forEach((v, i) => { %>
          <tr>
            <td class="muted"><%= (page-1)*10 + i + 1 %></td>
            <td>
              <a href="/admin/volunteer/<%= v.id %>" class="name-link"><%= v.name %></a>
              <div class="sub"><%= v.email %></div>
            </td>
            <td><%= v.phone %></td>
            <td><%= v.age %></td>
            <td><% if(v.skills){ %><span class="tag"><%= v.skills %></span><% }else{ %>—<% } %></td>
            <td><%= v.availability || '—' %></td>
            <td>
              <form method="POST" action="/admin/volunteer/<%= v.id %>/status" style="display:inline">
                <select name="status" class="status-select status-<%= v.status.toLowerCase() %>" onchange="this.form.submit()">
                  <option <%= v.status==='Pending'  ?'selected':'' %>>Pending</option>
                  <option <%= v.status==='Active'   ?'selected':'' %>>Active</option>
                  <option <%= v.status==='Inactive' ?'selected':'' %>>Inactive</option>
                </select>
              </form>
            </td>
            <td class="muted"><%= new Date(v.created_at).toLocaleDateString('en-IN') %></td>
            <td class="actions">
              <a href="/admin/volunteer/<%= v.id %>"      class="btn btn-xs btn-ghost">View</a>
              <a href="/admin/volunteer/<%= v.id %>/edit" class="btn btn-xs btn-outline">Edit</a>
              <form method="POST" action="/admin/volunteer/<%= v.id %>/delete" onsubmit="return confirm('Delete <%= v.name %>?')">
                <button class="btn btn-xs btn-danger">Del</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if(page > 1) { %>
          <a href="/admin/dashboard?q=<%= q %>&status=<%= status %>&page=<%= page-1 %>" class="page-btn">‹ Prev</a>
        <% } %>
        <% for(let p=1; p<=totalPages; p++) { %>
          <a href="/admin/dashboard?q=<%= q %>&status=<%= status %>&page=<%= p %>"
             class="page-btn <%= p===page?'active':'' %>"><%= p %></a>
        <% } %>
        <% if(page < totalPages) { %>
          <a href="/admin/dashboard?q=<%= q %>&status=<%= status %>&page=<%= page+1 %>" class="page-btn">Next ›</a>
        <% } %>
      </div>
      <% } %>
      <% } %>
    </div>
  </main>
  <footer><p>© 2025 Nayapankh VMS</p></footer>
</body>
</html>
