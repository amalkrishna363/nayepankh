<%- include('_layout_start', {
  title: 'Reports', page: 'reports',
  breadcrumb: '<span>Reports & Analytics</span>',
  head: '<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"><\/script>'
}) %>

<div class="admin-page-header">
  <h1 class="admin-page-title">Reports & Analytics</h1>
  <a href="/admin/export" class="btn btn-outline btn-sm">⬇ Export CSV</a>
</div>

<!-- KPI Cards -->
<div class="stat-cards">
  <div class="stat-card sc-purple">
    <div class="sc-icon">👥</div>
    <div class="sc-body"><div class="sc-num"><%= total %></div><div class="sc-label">Total Volunteers</div></div>
  </div>
  <div class="stat-card sc-green">
    <div class="sc-icon">✅</div>
    <div class="sc-body"><div class="sc-num"><%= active %></div><div class="sc-label">Active</div></div>
  </div>
  <div class="stat-card sc-yellow">
    <div class="sc-icon">⏳</div>
    <div class="sc-body"><div class="sc-num"><%= pending %></div><div class="sc-label">Pending</div></div>
  </div>
  <div class="stat-card sc-blue">
    <div class="sc-icon">📅</div>
    <div class="sc-body"><div class="sc-num"><%= thisMonth %></div><div class="sc-label">This Month</div></div>
  </div>
</div>

<!-- Charts -->
<div class="charts-grid">
  <div class="chart-card chart-wide">
    <div class="chart-card-header">
      <div class="chart-title">Monthly Registrations</div>
    </div>
    <canvas id="monthlyChart" height="80"></canvas>
  </div>
  <div class="chart-card">
    <div class="chart-card-header">
      <div class="chart-title">Volunteer Status</div>
    </div>
    <canvas id="statusChart"></canvas>
  </div>
  <div class="chart-card">
    <div class="chart-card-header">
      <div class="chart-title">Top Skills</div>
    </div>
    <canvas id="skillChart"></canvas>
  </div>
</div>

<%- include('_layout_end') %>

<script>
  const monthly  = <%- JSON.stringify(monthly) %>;
  const byStatus = <%- JSON.stringify(byStatus) %>;
  const skills   = <%- JSON.stringify(skills) %>;
  const C = ['#6366f1','#10b981','#f59e0b','#ef4444','#3b82f6','#8b5cf6','#ec4899','#14b8a6','#f97316','#84cc16'];

  new Chart(document.getElementById('monthlyChart'), {
    type: 'bar',
    data: {
      labels: monthly.map(d => d.month),
      datasets: [{ label: 'Registrations', data: monthly.map(d => d.count),
        backgroundColor: '#6366f1', borderRadius: 8, hoverBackgroundColor: '#4f46e5' }]
    },
    options: { responsive: true, plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
  });

  new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: {
      labels: byStatus.map(d => d.status),
      datasets: [{ data: byStatus.map(d => d.count), backgroundColor: C, borderWidth: 0 }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } }, cutout: '65%' }
  });

  new Chart(document.getElementById('skillChart'), {
    type: 'bar',
    data: {
      labels: skills.map(d => d.skills),
      datasets: [{ data: skills.map(d => d.count), backgroundColor: C, borderRadius: 6 }]
    },
    options: { indexAxis: 'y', responsive: true, plugins: { legend: { display: false } } }
  });
</script>
