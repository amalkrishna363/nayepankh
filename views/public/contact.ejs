<%- include('_header', { title: 'Contact', page: 'contact', head: '' }) %>

<section class="page-hero page-hero-sm">
  <div class="page-hero-inner">
    <div class="breadcrumb"><a href="/">Home</a> <span>›</span> Contact</div>
    <h1>Get In Touch</h1>
    <p>Have questions? We'd love to hear from you.</p>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    <div class="contact-grid">

      <!-- Info -->
      <div class="contact-info">
        <h2>Contact Information</h2>
        <p style="color:var(--sub);margin-bottom:1.8rem">Reach out through any of the channels below and we'll get back to you within 24 hours.</p>
        <div class="contact-items">
          <div class="contact-item">
            <div class="ci-icon">📧</div>
            <div>
              <div class="ci-label">Email</div>
              <div class="ci-val">hello@nayapankh.org</div>
            </div>
          </div>
          <div class="contact-item">
            <div class="ci-icon">📞</div>
            <div>
              <div class="ci-label">Phone</div>
              <div class="ci-val">+91 98765 43210</div>
            </div>
          </div>
          <div class="contact-item">
            <div class="ci-icon">📍</div>
            <div>
              <div class="ci-label">Address</div>
              <div class="ci-val">Mumbai, Maharashtra, India</div>
            </div>
          </div>
          <div class="contact-item">
            <div class="ci-icon">🕐</div>
            <div>
              <div class="ci-label">Working Hours</div>
              <div class="ci-val">Mon – Sat, 9:00 AM – 6:00 PM</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="contact-form-wrap">
        <% if (sent) { %>
        <div class="alert alert-success alert-lg" style="margin-bottom:1.5rem">
          <span class="alert-icon">✅</span>
          <div><strong>Message Sent!</strong><p>Thank you for reaching out. We'll respond within 24 hours.</p></div>
        </div>
        <% } %>
        <form method="POST" action="/contact" class="form form-card" style="box-shadow:none;padding:0">
          <div class="form-row">
            <div class="form-group">
              <label>Your Name <span class="req">*</span></label>
              <input type="text" name="name" placeholder="Full name" required>
            </div>
            <div class="form-group">
              <label>Email Address <span class="req">*</span></label>
              <input type="email" name="email" placeholder="you@example.com" required>
            </div>
          </div>
          <div class="form-group">
            <label>Subject</label>
            <select name="subject">
              <option>General Inquiry</option>
              <option>Volunteer Registration Help</option>
              <option>Partnership Opportunities</option>
              <option>Technical Support</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label>Message <span class="req">*</span></label>
            <textarea name="message" rows="5" placeholder="Write your message here…" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg">Send Message →</button>
        </form>
      </div>

    </div>
  </div>
</section>

<%- include('_footer') %>
