<%- include('_header', { title: 'About', page: 'about', head: '' }) %>

<section class="page-hero">
  <div class="page-hero-inner">
    <div class="breadcrumb"><a href="/">Home</a> <span>›</span> About</div>
    <h1>About Nayapankh</h1>
    <p>A platform built to connect passionate people with communities that need them.</p>
  </div>
</section>

<!-- MISSION -->
<section class="section" id="mission">
  <div class="section-inner">
    <div class="about-split">
      <div class="about-text">
        <div class="section-tag">Our Mission</div>
        <h2>Empowering communities through organised volunteerism</h2>
        <p>Nayapankh (meaning "new wings") was founded on the belief that every person has something valuable to contribute — a skill, a few hours, or a kind act.</p>
        <p>We built this platform to remove the friction from volunteering. No long forms, no bureaucracy. Just a simple system that connects the right people to the right cause at the right time.</p>
        <a href="/register" class="btn btn-primary" style="margin-top:1.2rem">Join Us Today →</a>
      </div>
      <div class="about-visual">
        <div class="about-stat-cards">
          <div class="asc asc-purple"><div class="asc-num">500+</div><div class="asc-label">Volunteers Managed</div></div>
          <div class="asc asc-green"><div class="asc-num">50+</div><div class="asc-label">Communities Served</div></div>
          <div class="asc asc-orange"><div class="asc-num">5</div><div class="asc-label">Years of Service</div></div>
          <div class="asc asc-blue"><div class="asc-num">10K+</div><div class="asc-label">Hours Contributed</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- VALUES -->
<section class="section section-alt">
  <div class="section-inner">
    <div class="section-tag">Our Values</div>
    <h2 class="section-title">What we stand for</h2>
    <div class="values-grid">
      <div class="value-item">
        <div class="value-icon">💡</div>
        <h3>Transparency</h3>
        <p>Every volunteer knows exactly how their time is being used and the impact it creates.</p>
      </div>
      <div class="value-item">
        <div class="value-icon">🌍</div>
        <h3>Inclusivity</h3>
        <p>We welcome volunteers of all backgrounds, ages, and skill levels.</p>
      </div>
      <div class="value-item">
        <div class="value-icon">⚡</div>
        <h3>Efficiency</h3>
        <p>Our systems are designed to make volunteering as easy and impactful as possible.</p>
      </div>
      <div class="value-item">
        <div class="value-icon">🫂</div>
        <h3>Community</h3>
        <p>We believe in the power of people coming together to create lasting change.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-inner">
    <h2>Want to be part of our story?</h2>
    <p>Register as a volunteer and become a changemaker today.</p>
    <a href="/register" class="btn btn-hero">Get Started →</a>
  </div>
</section>

<%- include('_footer') %>
